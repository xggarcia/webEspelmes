# =============================================================================
# webEspelmes — Environment template
# Copy to `.env` for local dev. Never commit real secrets.
# =============================================================================

# --- Shared ---
NODE_ENV=development
TZ=Europe/Madrid

# --- Database (Postgres) ---
POSTGRES_USER=espelmes
POSTGRES_PASSWORD=espelmes_dev_password
POSTGRES_DB=espelmes
POSTGRES_PORT=5432
DATABASE_URL=postgresql://espelmes:espelmes_dev_password@localhost:5432/espelmes?schema=public

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- API (NestJS) ---
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# JWT — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_me_access_secret_min_32_chars_0000000000
JWT_REFRESH_SECRET=replace_me_refresh_secret_min_32_chars_000000000
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Seeded admin (created by prisma seed)
ADMIN_EMAIL=admin@espelmes.local
ADMIN_PASSWORD=ChangeMe!2026
ADMIN_NAME=Administradora

# --- Stripe (test mode) ---
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_CURRENCY=eur

# --- Mail ---
MAIL_DRIVER=console
MAIL_FROM="Espelmes de ca la mare <hola@espelmes.local>"
RESEND_API_KEY=

# --- Web (Next.js) ---
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
NEXT_PUBLIC_DEFAULT_LOCALE=ca
NEXT_PUBLIC_SUPPORTED_LOCALES=ca,es

# --- Uploads ---
UPLOADS_DRIVER=local
UPLOADS_LOCAL_PATH=./uploads
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto

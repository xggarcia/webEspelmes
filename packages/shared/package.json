{
  "name": "@espelmes/shared",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./configurator": { "types": "./dist/configurator/index.d.ts", "default": "./dist/configurator/index.js" },
    "./auth": { "types": "./dist/auth/index.d.ts", "default": "./dist/auth/index.js" },
    "./catalog": { "types": "./dist/catalog/index.d.ts", "default": "./dist/catalog/index.js" },
    "./orders": { "types": "./dist/orders/index.d.ts", "default": "./dist/orders/index.js" },
    "./commands": { "types": "./dist/commands/index.d.ts", "default": "./dist/commands/index.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}

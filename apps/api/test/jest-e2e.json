{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": { "^.+\\.(t|j)s$": "ts-jest" },
  "moduleNameMapper": {
    "^@espelmes/shared(.*)$": "<rootDir>/../../../packages/shared/src$1",
    "^@/(.*)$": "<rootDir>/../src/$1"
  }
}
